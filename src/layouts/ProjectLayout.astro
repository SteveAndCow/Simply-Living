---
import BaseLayout from './BaseLayout.astro';
import { imageUrl, videoPoster, videoUrl } from '@lib/cloudinary';
import { formatDate } from '@lib/utils';

interface Props {
  title: string;
  client: string;
  date: Date;
  description: string;
  heroVideo?: string;
  heroImage?: string;
  gallery?: string[];
  credits: { role: string; name: string }[];
  externalVideoUrl?: string;
  category: string;
  services: string[];
  thumbnail?: string;
}

const {
  title,
  client,
  date,
  description,
  heroVideo,
  heroImage,
  gallery,
  credits,
  externalVideoUrl,
  category,
  services,
  thumbnail,
} = Astro.props;

const formattedDate = formatDate(date);
const posterUrl = thumbnail
  ? imageUrl(thumbnail, { width: 1920, quality: 'auto' })
  : heroVideo
    ? videoPoster(heroVideo, { width: 1920 })
    : heroImage
      ? imageUrl(heroImage, { width: 1920, quality: 'auto' })
      : '';
---

<BaseLayout title={title} description={description} bodyClass="page-project">
  <article class="project-page">
    <section class="project-hero">
      {
        heroVideo ? (
          <video
            class="project-hero-video"
            src={videoUrl(heroVideo, { quality: 'auto', format: 'auto', width: 1920 })}
            poster={posterUrl}
            autoplay
            muted
            loop
            playsinline
          />
        ) : (
          <img class="project-hero-video" src={posterUrl} alt="" />
        )
      }
      <div class="project-hero-overlay"></div>

      <div class="project-hero-shell">
        <div class="container project-hero-layout">
          <div class="project-hero-copy panel">
            <p class="project-kicker">
              {client} / {category.replace('-', ' ')} / {formattedDate}
            </p>
            <h1 class="project-title">{title}</h1>
            <p class="project-description">{description}</p>

            <div class="project-hero-actions">
              {externalVideoUrl && (
                <a
                  href={externalVideoUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="pill-button"
                >
                  Watch full video
                </a>
              )}
              <a href="/work" class="ghost-button">Back to archive</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="project-body section-shell">
      <div class="container project-body-grid">
        <div class="project-story">
          <p class="eyebrow">Project story</p>
          {Astro.slots.has('default') && (
            <div class="project-rich">
              <slot />
            </div>
          )}
        </div>

        <aside class="project-sidebar panel">
          <div class="project-meta-group">
            <p class="project-meta-label">Client</p>
            <p class="project-meta-value">{client}</p>
          </div>

          <div class="project-meta-group">
            <p class="project-meta-label">Category</p>
            <p class="project-meta-value">{category.replace('-', ' ')}</p>
          </div>

          <div class="project-meta-group">
            <p class="project-meta-label">Release</p>
            <p class="project-meta-value">{formattedDate}</p>
          </div>

          <div class="project-meta-group">
            <p class="project-meta-label">Services</p>
            <ul class="project-service-list">
              {services.map((service) => <li>{service}</li>)}
            </ul>
          </div>
        </aside>
      </div>
    </section>

    {gallery && gallery.length > 0 && (
      <section class="gallery-section section-shell">
        <div class="container gallery-grid">
          {gallery.map((imageId) => (
            <figure class="gallery-card panel">
              <img
                src={imageUrl(imageId, { width: 1600, quality: 'auto' })}
                alt=""
                loading="lazy"
                class="gallery-image"
              />
            </figure>
          ))}
        </div>
      </section>
    )}

    <section class="credits-section section-shell">
      <div class="container credits-layout">
        <div>
          <p class="eyebrow">Credits</p>
          <h2 class="credits-title">The crew behind the frame.</h2>
        </div>

        <div class="credits-grid">
          {credits.map(({ role, name }) => (
            <div class="credit-card panel">
              <p class="credit-role">{role}</p>
              <p class="credit-name">{name}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .project-page {
    padding-top: clamp(5.8rem, 8vw, 7rem);
  }

  .project-hero {
    position: relative;
    min-height: min(100vh, 56rem);
    overflow: clip;
  }

  .project-hero-video,
  .project-hero-overlay {
    position: absolute;
    inset: 0;
  }

  .project-hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.94) contrast(1.02);
  }

  .project-hero-overlay {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0.86)),
      linear-gradient(90deg, rgba(255, 255, 255, 0.62), rgba(255, 255, 255, 0.16) 45%, rgba(255, 255, 255, 0.66));
  }

  .project-hero-shell {
    position: relative;
    z-index: 1;
    min-height: min(100vh, 56rem);
    display: flex;
    align-items: flex-end;
    padding: clamp(2rem, 5vw, 3rem) 0;
  }

  .project-hero-layout {
    width: min(100%, var(--max-width));
  }

  .project-hero-copy {
    max-width: min(40rem, 100%);
    padding: clamp(1.25rem, 3vw, 2rem);
  }

  .project-kicker,
  .project-meta-label,
  .credit-role {
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .project-title {
    margin-top: 0.85rem;
    font-size: clamp(3.2rem, 7vw, 6.5rem);
    line-height: 0.9;
    letter-spacing: -0.05em;
  }

  .project-description {
    margin-top: 1rem;
    max-width: 30rem;
    font-size: clamp(1rem, 1.6vw, 1.15rem);
  }

  .project-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.4rem;
  }

  .project-body-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 24rem);
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: start;
  }

  .project-story {
    max-width: 48rem;
  }

  .project-rich {
    margin-top: 1.3rem;
  }

  :global(.project-rich p),
  :global(.project-rich ul),
  :global(.project-rich ol) {
    margin-bottom: 1.15rem;
    font-size: clamp(1rem, 1.5vw, 1.14rem);
    color: var(--color-text-soft);
  }

  :global(.project-rich em) {
    font-family: var(--font-display);
    font-size: 1.08em;
  }

  :global(.project-rich h2),
  :global(.project-rich h3) {
    margin: 2.2rem 0 0.8rem;
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 0.95;
  }

  .project-sidebar {
    position: sticky;
    top: 7rem;
    display: grid;
    gap: 1.15rem;
    padding: 1.25rem;
  }

  .project-meta-value {
    margin-top: 0.3rem;
    color: var(--color-text);
  }

  .project-service-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 0.65rem;
  }

  .project-service-list li {
    padding: 0.58rem 0.82rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--color-border);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .gallery-card {
    overflow: hidden;
  }

  .gallery-image {
    width: 100%;
    height: 100%;
    min-height: 20rem;
    object-fit: cover;
  }

  .credits-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: start;
  }

  .credits-title {
    margin-top: 0.8rem;
    font-size: clamp(2.4rem, 4.5vw, 4.2rem);
    line-height: 0.92;
    letter-spacing: -0.04em;
  }

  .credits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
    gap: 0.9rem;
  }

  .credit-card {
    padding: 1rem;
  }

  .credit-name {
    margin-top: 0.45rem;
    font-size: clamp(1.25rem, 2.4vw, 1.8rem);
    color: var(--color-text);
  }

  @media (max-width: 1024px) {
    .project-body-grid,
    .credits-layout {
      grid-template-columns: 1fr;
    }

    .project-sidebar {
      position: static;
    }
  }

  @media (max-width: 720px) {
    .project-page {
      padding-top: 7rem;
    }

    .gallery-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
