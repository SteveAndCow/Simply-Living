---
import BaseLayout from '@layouts/BaseLayout.astro';

// Team members with placeholder data
const team = [
  {
    name: 'Jordan Lee',
    role: 'Director & Founder',
    bio: "With a background in cinematography and a passion for storytelling, Jordan founded Simply Living Studios to create a space where artistic vision meets technical excellence. Over the past five years, they've directed dozens of music videos and brand campaigns.",
    image: 'https://picsum.photos/seed/jordan/400/400',
  },
  {
    name: 'Alex Chen',
    role: 'Director of Photography',
    bio: 'Alex brings a keen eye for composition and lighting to every project. Trained in film school and seasoned through countless productions, they excel at translating creative concepts into stunning visuals.',
    image: 'https://picsum.photos/seed/alex/400/400',
  },
  {
    name: 'Taylor Morrison',
    role: 'Lead Editor',
    bio: "Taylor's editing style balances rhythm and emotion, finding the perfect pace for every story. With expertise in color grading and sound design, they ensure every frame serves the narrative.",
    image: 'https://picsum.photos/seed/taylor/400/400',
  },
];

// Placeholder client logos
const clients = [
  'Client A',
  'Client B',
  'Client C',
  'Client D',
  'Client E',
  'Client F',
  'Client G',
  'Client H',
];
---

<BaseLayout
  title="About"
  description="Learn about Simply Living Studios - a Toronto-based creative agency specializing in video production."
>
  <div class="about-page">
    <!-- Studio Story -->
    <section class="studio-story">
      <div class="container">
        <h1 class="story-title">Creating stories that matter</h1>
        <div class="story-content">
          <div class="story-text">
            <p>
              Simply Living Studios was born from a simple belief: that every project deserves
              authentic storytelling and meticulous craft. Founded in Toronto in 2019, we've grown
              from a one-person operation into a collaborative creative agency.
            </p>
            <p>
              Our work spans music videos, brand content, and commercial projects—but what ties it
              all together is our commitment to visual excellence and genuine narrative. We don't
              chase trends; we create timeless work that resonates.
            </p>
            <p>
              Based in Toronto, we work with artists, brands, and organizations who value
              creativity, collaboration, and honest storytelling. Whether it's a indie music video
              or a major brand campaign, we approach every project with the same dedication and
              care.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Team -->
    <section class="team-section">
      <div class="container">
        <h2 class="section-title">The Team</h2>
        <div class="team-grid">
          {
            team.map((member) => (
              <div class="team-member">
                <div class="member-image">
                  <img src={member.image} alt={member.name} loading="lazy" />
                </div>
                <div class="member-info">
                  <h3 class="member-name">{member.name}</h3>
                  <p class="member-role">{member.role}</p>
                  <p class="member-bio">{member.bio}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Clients -->
    <section class="clients-section">
      <div class="container">
        <h2 class="section-title">Trusted By</h2>
        <p class="clients-intro">
          We've had the privilege of working with incredible artists, brands, and organizations.
        </p>
        <div class="clients-grid">
          {
            clients.map((client) => (
              <div class="client-logo">
                <span class="client-name">{client}</span>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="about-cta">
      <div class="container">
        <h2 class="cta-title">Let's create together</h2>
        <p class="cta-text">
          Interested in working with us? We'd love to hear about your project.
        </p>
        <a href="/contact" class="cta-button">Get in Touch</a>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .about-page {
    padding-top: 120px;
  }

  /* Studio Story */
  .studio-story {
    padding: var(--space-3xl) 0;
    border-bottom: 1px solid rgba(12, 13, 18, 0.12);
  }

  .story-title {
    font-family: var(--font-display);
    font-size: var(--text-title);
    margin-bottom: var(--space-2xl);
    max-width: 800px;
  }

  .story-content {
    max-width: 800px;
  }

  .story-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .story-text p {
    font-size: var(--text-lg);
    line-height: 1.8;
    color: var(--color-text-secondary);
  }

  /* Team Section */
  .team-section {
    padding: var(--space-3xl) 0;
    border-bottom: 1px solid rgba(12, 13, 18, 0.12);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: var(--text-title);
    margin-bottom: var(--space-2xl);
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-2xl);
  }

  .team-member {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .member-image {
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    background-color: #f0f0f0;
  }

  .member-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%);
    transition: filter var(--transition-medium) var(--ease-smooth);
  }

  .team-member:hover .member-image img {
    filter: grayscale(0%);
  }

  .member-name {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    margin-bottom: var(--space-xs);
  }

  .member-role {
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-md);
  }

  .member-bio {
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--color-text-secondary);
  }

  /* Clients Section */
  .clients-section {
    padding: var(--space-3xl) 0;
    border-bottom: 1px solid rgba(12, 13, 18, 0.12);
  }

  .clients-intro {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-2xl);
    max-width: 600px;
  }

  .clients-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-xl);
  }

  .client-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-xl);
    border: 1px solid rgba(12, 13, 18, 0.12);
    min-height: 120px;
    transition: border-color var(--transition-fast) var(--ease-smooth);
  }

  .client-logo:hover {
    border-color: rgba(12, 13, 18, 0.22);
  }

  .client-name {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* About CTA */
  .about-cta {
    padding: var(--space-3xl) 0;
    text-align: center;
  }

  .cta-title {
    font-family: var(--font-display);
    font-size: var(--text-title);
    margin-bottom: var(--space-lg);
  }

  .cta-text {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto var(--space-2xl);
  }

  .cta-button {
    display: inline-block;
    font-size: var(--text-lg);
    padding: var(--space-md) var(--space-2xl);
    border: 1px solid var(--color-text);
    text-decoration: none;
    color: var(--color-text);
    transition: all var(--transition-fast) var(--ease-smooth);
  }

  .cta-button:hover {
    background-color: var(--color-text);
    color: var(--color-bg);
    opacity: 1;
  }

  /* Mobile Responsive */
  @media (max-width: 768px) {
    .about-page {
      padding-top: 80px;
    }

    .team-grid {
      grid-template-columns: 1fr;
    }

    .clients-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-md);
    }
  }
</style>
