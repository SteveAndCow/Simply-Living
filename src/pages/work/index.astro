---
import BaseLayout from '@layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { imageUrl } from '@lib/cloudinary';

const sortedProjects = (await getCollection('projects')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<BaseLayout title="Work" description="Selected work by Simply Living Studios." bodyClass="page-work">
  <div class="work-page">
    <section class="work-hero section-shell">
      <div class="container work-hero-grid">
        <div class="work-hero-copy">
          <p class="eyebrow">Work archive</p>
          <h1 class="work-title">A smoother archive for the projects behind the studio.</h1>
        </div>
        <p class="work-intro">
          Every case study opens with motion first, then drops into the context: client, category,
          creative story, credits, and supporting stills.
        </p>
      </div>
    </section>

    <section class="work-list section-shell">
      <div class="container work-stack">
        {
          sortedProjects.map((project, index) => (
            <a
              href={`/work/${project.slug}`}
              class:list={['work-card panel', { 'work-card--lead': index === 0 }]}
            >
              <div class="work-card-media">
                <img
                  src={imageUrl(project.data.thumbnail, { width: 1600, quality: 'auto' })}
                  alt={project.data.title}
                  loading={index === 0 ? 'eager' : 'lazy'}
                />
              </div>

              <div class="work-card-content">
                <p class="work-card-kicker">
                  {project.data.client} / {project.data.category.replace('-', ' ')} /{' '}
                  {project.data.date.getFullYear()}
                </p>
                <h2 class="work-card-title">{project.data.title}</h2>
                <p class="work-card-description">{project.data.description}</p>
                <ul class="work-card-services">
                  {project.data.services.slice(0, 4).map((service) => <li>{service}</li>)}
                </ul>
              </div>
            </a>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .work-page {
    padding-top: clamp(7rem, 10vw, 8.5rem);
  }

  .work-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 28rem);
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: end;
  }

  .work-title {
    font-size: clamp(3.4rem, 8vw, 7rem);
    line-height: 0.9;
    letter-spacing: -0.05em;
    max-width: 10ch;
  }

  .work-intro {
    font-size: clamp(1rem, 1.6vw, 1.15rem);
  }

  .work-stack {
    display: grid;
    gap: 1.4rem;
  }

  .work-card {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(18rem, 0.8fr);
    gap: 0;
    overflow: hidden;
  }

  .work-card:hover,
  .work-card:focus-visible {
    opacity: 1;
    transform: translateY(-4px);
  }

  .work-card--lead {
    grid-template-columns: minmax(0, 1.3fr) minmax(20rem, 0.7fr);
  }

  .work-card-media {
    min-height: clamp(22rem, 48vw, 44rem);
    overflow: hidden;
  }

  .work-card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1s var(--ease-emphasis);
  }

  .work-card:hover .work-card-media img,
  .work-card:focus-visible .work-card-media img {
    transform: scale(1.04);
  }

  .work-card-content {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 1rem;
    padding: clamp(1.2rem, 2.4vw, 2rem);
    background: var(--color-panel-strong);
  }

  .work-card-kicker {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  .work-card-title {
    font-size: clamp(2.6rem, 5vw, 4.8rem);
    line-height: 0.9;
    letter-spacing: -0.05em;
  }

  .work-card-description {
    max-width: 28rem;
  }

  .work-card-services {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .work-card-services li {
    padding: 0.55rem 0.82rem;
    border-radius: var(--radius-pill);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  @media (max-width: 960px) {
    .work-hero-grid,
    .work-card,
    .work-card--lead {
      grid-template-columns: 1fr;
    }

    .work-card-media {
      min-height: 18rem;
    }
  }
</style>
