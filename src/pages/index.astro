---
import ProjectExperience from '@components/svelte/ProjectExperience.svelte';
import BaseLayout from '@layouts/BaseLayout.astro';
import { imageUrl, videoPoster, videoUrl } from '@lib/cloudinary';
import { getCollection } from 'astro:content';

const allProjects = (await getCollection('projects')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const featuredProjects = allProjects.filter((project) => project.data.featured);
const heroProjects = featuredProjects.length > 0 ? featuredProjects : allProjects;

const slugify = (value: string) =>
  value
    .toLowerCase()
    .trim()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-+|-+$/g, '');

const mediaUrl = (media: { type: 'image' | 'video'; id: string }) =>
  media.type === 'video'
    ? videoUrl(media.id, { quality: 'auto', format: 'auto', width: 960 })
    : imageUrl(media.id, { quality: 'auto', format: 'auto', width: 1200 });

const mapMedia = (media: {
  type: 'image' | 'video';
  id: string;
  alt?: string;
  caption?: string;
  layout?: 'small' | 'medium' | 'large' | 'wide';
}) => ({
  type: media.type,
  src: mediaUrl(media),
  alt: media.alt ?? '',
  caption: media.caption,
  layout: media.layout ?? 'medium',
});

const experienceProjects = heroProjects.map((project) => {
  const displayTitle = project.data.displayTitle ?? project.data.title;
  const info = project.data.info ?? { text: [], media: [] };
  const previewMedia =
    project.data.heroVideo
      ? {
          type: 'video' as const,
          src: videoUrl(project.data.heroVideo, {
            quality: 'auto',
            format: 'auto',
            width: 1920,
          }),
          poster: videoPoster(project.data.heroVideo, { width: 1920 }),
        }
      : {
          type: 'image' as const,
          src: imageUrl(project.data.heroImage ?? project.data.thumbnail, {
            quality: 'auto',
            format: 'auto',
            width: 1920,
          }),
        };
  const fullMedia =
    project.data.fullVideo
      ? {
          type: 'video' as const,
          src: videoUrl(project.data.fullVideo, {
            quality: 'auto',
            format: 'auto',
            width: 1920,
          }),
          poster: videoPoster(project.data.fullVideo, { width: 1920 }),
          duration: project.data.fullVideoDuration,
        }
      : previewMedia;

  return {
    slug: slugify(displayTitle),
    displayTitle,
    client: project.data.client,
    category: project.data.category,
    description: project.data.description,
    previewMedia,
    fullMedia,
    btsMedia: project.data.btsMedia.map(mapMedia),
    info: {
      text: info.text.length > 0 ? info.text : [project.data.description],
      media: info.media.map(mapMedia),
    },
    credits: project.data.credits,
  };
});
---

<BaseLayout
  title="Simply Living Studios"
  description="Creative direction, cinematic production, and editorial post for artists and brands."
  bodyClass="page-home"
  headerVariant="overlay"
  hideFooter
>
  <ProjectExperience projects={experienceProjects} client:load />
</BaseLayout>
