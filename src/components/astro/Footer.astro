---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-content">
    <div class="footer-left">
      <p class="copyright">© {currentYear} Simply Living Studios</p>
    </div>

    <div class="footer-right">
      <nav class="social-links">
        <a
          href="https://instagram.com/simplylivingstudios"
          target="_blank"
          rel="noopener noreferrer"
          class="social-link"
          aria-label="Instagram"
        >
          Instagram
        </a>
        <a
          href="mailto:hello@simplylivingstudios.com"
          class="social-link"
          aria-label="Email"
        >
          Email
        </a>
      </nav>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-2xl) var(--padding, var(--padding-desktop));
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .copyright {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .social-links {
    display: flex;
    gap: var(--space-lg);
  }

  .social-link {
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast) var(--ease-smooth);
  }

  .social-link:hover {
    color: var(--color-text);
  }

  /* Mobile Styles */
  @media (max-width: 768px) {
    .footer {
      padding: var(--space-xl) var(--padding, var(--padding-mobile));
    }

    .footer-content {
      flex-direction: column;
      gap: var(--space-md);
      text-align: center;
    }

    .social-links {
      flex-direction: column;
      gap: var(--space-sm);
    }
  }
</style>
